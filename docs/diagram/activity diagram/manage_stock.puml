@startuml
!pragma theme plain
skinparam activity {
  BackgroundColor white
  BorderColor black
  FontSize 11
}
skinparam Arrow {
  Color #333333
  FontSize 10
}
skinparam rectangle {
  BackgroundColor white
  BorderColor #333333
}

|Owner|
start
:Login ke sistem;
:Memilih menu "Inventori / Stok";
-[#blue]-> :Buka halaman stok;

|Sistem|
:Tampilkan daftar produk + stok;
:Tampilkan peringatan stok menipis
(stock <= min_stock);
:[#green]-> :Tampilkan data stok;

|Owner|
if (Ingin filter kategori?) then (Ya)
  :Pilih kategori dari dropdown;
  -[#blue]-> :Kirim filter;
  |Sistem|
  :Filter ulang daftar produk;
  -[#green]-> :Tampilkan hasil filter;
  |Owner|
endif

partition "Adjust Stok (Opname)" {
  |Owner|
  :Pilih produk yang akan disesuaikan;
  :Klik tombol "Adjust Stok";
  -[#blue]-> :Buka form adjust;

  |Sistem|
  :Tampilkan form adjust stok;
  :Tampilkan stok saat ini (stock_before);
  -[#green]-> :Form siap diisi;

  |Owner|
  :Input stok baru (hasil fisik);
  :Input alasan penyesuaian;
  -[#blue]-> :Kirim data adjust;

  |Sistem|
  :Hitung selisih stok;
  
  if (Selisih > 0?) then (Ya)
    :Movement type = "IN";
    :qty = +selisih;
  elseif (Selisih < 0?) then (Ya)
    :Movement type = "OUT";
    :qty = -|selisih|;
  else (Tidak)
    :Tidak ada perubahan;
    -[#green]-> :Tampilkan "Tidak ada perubahan";
    |Owner|
    stop
  endif

  :Catat stock_before, stock_after, qty;
  :Simpan ke tabel stock_movements;
  :Update stok produk di tabel products;
  -[#green]-> :Tampilkan notifikasi sukses;
  |Owner|
  :Lihat stok terbaru;
}

partition "Riwayat Stok" {
  |Owner|
  :Pilih produk yang ingin dilihat;
  :Klik tombol "Riwayat Stok";
  -[#blue]-> :Minta data riwayat;

  |Sistem|
  :Ambil log pergerakan stok;
  :Tampilkan tabel riwayat;
  -[#green]-> :Tampilkan data riwayat;

  |Owner|
  if (Ingin filter?) then (Ya)
    :Filter berdasarkan tanggal;
    :Filter berdasarkan movement type;
    -[#blue]-> :Kirim filter;
    |Sistem|
    :Filter ulang data;
    -[#green]-> :Tampilkan hasil filter;
  else (Tidak)
  endif
}

|Owner|
stop
@enduml