@startuml
!pragma theme plain
skinparam activity {
  BackgroundColor white
  BorderColor black
  FontSize 11
}
skinparam Arrow {
  Color #333333
  FontSize 10
}
skinparam rectangle {
  BackgroundColor white
  BorderColor #333333
}

|Kasir|
start
:Pilih metode "Midtrans";
-[#blue]-> :Kirim permintaan pembayaran;

|Sistem|
:Panggil Transaction::create()
→ status PENDING;
:Panggil Midtrans::generateSnapToken();
-[#green]-> :Tampilkan popup Snap.js;

|Midtrans|
:Tampilkan popup pembayaran;
-[#green]-> :Tampilkan form/redirect;

|Customer|
:Pilih metode pembayaran;

if (Kartu Kredit?) then (Ya)
  :Input nomor kartu, expiry, CVV;
  :Jika 3DS, input OTP "112233";
  :Klik "Bayar";
else (E-Wallet / QRIS)
  :Scan QR / redirect ke app;
  :Konfirmasi pembayaran;
endif

-[#blue]-> :Kirim konfirmasi;

|Midtrans|
:Proses pembayaran;
:Kirim notifikasi ke webhook;
-[#blue]-> :Notifikasi;

|Sistem|
:Verifikasi signature key;
:Update payment_status → "PAID";
:Catat payment_reference;
:Update stok (jika perlu);
-[#green]-> :Tampilkan halaman sukses;

|Kasir|
:Tampilkan receipt_number;
if (Cetak struk?) then (Ya)
  :Cetak struk thermal;
else (Tidak)
endif

stop
@enduml