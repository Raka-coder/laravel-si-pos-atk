@startuml
!pragma theme plain
skinparam activity {
  BackgroundColor white
  BorderColor black
  FontSize 11
}
skinparam Arrow {
  Color #333333
  FontSize 10
}
skinparam rectangle {
  BackgroundColor white
  BorderColor #333333
}

|Kasir|
start
:Login ke sistem;
:Memilih menu POS;

repeat
  :Cari produk (scan barcode / nama);
  -[#blue]-> :Kirim data pencarian;

  |Sistem|
  :Tampilkan hasil produk;
  :Validasi stok dan harga;
  -[#green]-> :Tampilkan data;

  |Kasir|
  :Input jumlah produk;
  -[#blue]-> :Tambah ke keranjang;

  |Sistem|
  :Hitung subtotal sementara;
  -[#green]-> :Tampilkan subtotal;

  |Kasir|
  :Tambah produk lain?;
repeat while (Ya) is (Tidak)

|Kasir|
:Tampilkan ringkasan keranjang;
:Klik "Checkout";
-[#blue]-> :Proses checkout;

|Sistem|
if (Pelanggan minta diskon?) then (Ya)
  |Kasir|
  :Input diskon;
  -[#blue]-> :Kirim data diskon;
  |Sistem|
  :Validasi & hitung ulang;
else (Tidak)
endif

|Sistem|
:Hitung total akhir + pajak;
-[#green]-> :Tampilkan total;

|Kasir|
:Pilih metode pembayaran;
-[#blue]-> :Kirim pilihan;

|Sistem|
if (Metode = Cash?) then (Ya)
  |Kasir|
  :Input jumlah uang;
  -[#blue]-> :Proses;
  |Sistem|
  :Hitung kembalian;
  -[#green]-> :Tampilkan kembalian;
elseif (Metode = QRIS?) then (Ya)
  |Sistem|
  :Tampilkan QRIS statis;
  |Kasir|
  :Konfirmasi bayar;
  -[#blue]-> :Konfirmasi;
elseif (Metode = Midtrans?) then (Ya)
  |Sistem|
  :Generate token & popup;
  |Kasir|
  :Customer bayar via popup;
  |Sistem|
  :Terima webhook;
else (Lainnya)
endif

|Sistem|
:Simpan transaksi ke DB;
:Kurangi stok;
:Generate receipt number;
-[#green]-> :Tampilkan sukses;

|Kasir|
if (Cetak struk?) then (Ya)
  -[#blue]-> :Cetak;
  |Sistem|
  :Cetak thermal;
else (Tidak)
endif

stop
@enduml