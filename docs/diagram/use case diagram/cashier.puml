@startuml
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam usecaseBackgroundColor #FFF8E7
skinparam usecaseBorderColor #D35400

actor "Kasir / Admin" as cashier

rectangle "Sistem POS ATK - Operasional Toko" {

  package "Manajemen Produk & Stok" {
    usecase "Lihat Produk (Read Only)" as UC08
    usecase "Cek Stok" as UC11
    usecase "Peringatan Stok Menipis" as UC14
  }

  package "Point of Sale (POS)" {
    usecase "Buat Transaksi Baru" as UC15
    usecase "Tambah Item ke Keranjang" as UC16
    usecase "Hapus Item dari Keranjang" as UC17
    usecase "Terapkan Diskon" as UC18
    usecase "Hitung Total" as UC19
    usecase "Pilih Metode Pembayaran" as UC20
    usecase "Proses Pembayaran Tunai" as UC21
    usecase "Proses Pembayaran QRIS" as UC22
    usecase "Proses Pembayaran Midtrans" as UC23
    usecase "Cetak Struk" as UC24
  }

  package "Riwayat Transaksi" {
    usecase "Lihat Riwayat Transaksi (Mandiri)" as UC26
    usecase "Lihat Detail Transaksi" as UC27
  }
}

cashier --> UC08
cashier --> UC11
cashier --> UC14
cashier --> UC15
cashier --> UC16
cashier --> UC17
cashier --> UC18
cashier --> UC19
cashier --> UC20
cashier --> UC21
cashier --> UC22
cashier --> UC23
cashier --> UC24
cashier --> UC26
cashier --> UC27

' Include & Extend relationships
UC15 .> UC16 : includes
UC15 .> UC17 : includes
UC15 .> UC19 : includes
UC15 .> UC20 : includes
UC20 .> UC21 : extends
UC20 .> UC22 : extends
UC20 .> UC23 : extends
UC15 .> UC24 : extends
@enduml