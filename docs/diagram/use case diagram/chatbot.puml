@startuml
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam usecaseBackgroundColor #F0FFF0
skinparam usecaseBorderColor #27AE60

actor "Owner" as owner
actor "Kasir" as cashier
actor "AI Assistant" as ai

rectangle "Sistem POS ATK - AI Decision Support" {

  package "Manajemen Chatbot" {
    usecase "Mulai Percakapan" as UC41
    usecase "Lihat Riwayat Chat" as UC45
  }

  package "Analitik & Rekomendasi" {
    usecase "Tanya Bisnis" as UC42
    usecase "Rekomendasi Stok" as UC43
    usecase "Insight Penjualan" as UC44
  }

  package "Data Pendukung AI" {
    usecase "Ambil Data Stok Terkini" as DS01
    usecase "Ambil Data Penjualan" as DS02
    usecase "Ambil Data Produk Terlaris" as DS03
    usecase "Ambil Data Pengeluaran" as DS04
  }
}

owner --> UC41
owner --> UC45
owner --> UC42
owner --> UC43
owner --> UC44

cashier --> UC41
cashier --> UC45
cashier --> UC42
cashier --> UC43
cashier --> UC44

ai --> DS01
ai --> DS02
ai --> DS03
ai --> DS04

UC42 .> UC43 : extends
UC42 .> UC44 : extends
UC42 .> UC45 : includes
@enduml